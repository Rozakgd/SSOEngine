# Build directories
cmake-build-*/
*.o
*.obj
*.exe
build/
*/build/

# IDE files
.idea/
.vscode/

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# Python
__pycache__/
*.pyc

# Android Build Artifacts & Temporary Files
# Native libraries (build outputs)
*.so
libSSOEngine.so
# Ignore build output folders in lib/ root
lib/arm64-v8a/
lib/armeabi-v7a/
lib/x86/
lib/x86_64/
# But keep lib/android/ for essential dependencies (see exceptions at bottom)

# APK build artifacts
*.apk
*.unsigned.apk
*.aligned.apk
android/bin/
android/gen/
android/obj/
android/src/com/ssogames/ssoengine/R.java
temp_pkg/

# Android signing & security files
*.keystore
*.jks
debug.keystore
ssoengine.keystore
android/*.keystore

# Android temporary staging folders
arm64-v8a/
jniLibs/
libs/

# SSOEngine Safety - High Risk Files
bfd.h
libbfd.a
libopcodes.a
dis-asm.h
ctf.h
ctf-api.h
libctf.a
libctf-nobfd.a
libmangle.h
libmangle.a
libsframe.a
libiberty.a
libiberty/
diagnostics.h
plugin-api.h
sframe-api.h
sframe.h
ansidecl.h
gnumake.h
symcat.h

# Debugging tools
gdb/
bfd-plugins/
gcc/

# Asset packer executable
00_BuildTools/sso_packer.exe
00_BuildTools/*.exe

# Generated files
assets_data.h
assets.sso
resource.o

# Risky executables (keep Android .so files in ignore)
*.dll
*.dylib

# Backup folders
backup_risky/

# Large binary files (over 1MB)
# Note: Kalau file di lib/ atau include/ masih ilang, 
# hapus dua baris di bawah ini:
*.a
*.lib

# Security sensitive
*.pem
*.key
*.crt

# Generated files
include/assets_data.h

# OS files
.DS_Store
Thumbs.db

# Exception: Keep essential Android library dependencies
!lib/android/
!lib/android/**
!lib/android/*.a
!lib/android/**/*.a

# Ignore other lib subdirectories
lib/gcc/
lib/bfd-plugins/